{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "claxi",
    "public": "web/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/ice-config",
        "function": "getIceConfig"
      },
      {
        "source": "/verify-paystack",
        "function": "verifyPaystack"
      },
      {
        "source": "/finalize-session-billing",
        "function": "finalizeSessionBilling"
      },
      {
        "source": "/pricing-quote",
        "function": "getPricingQuote"
      },
      {
        "source": "/sync-student-growth",
        "function": "syncStudentGrowth"
      },
      {
        "source": "/image-ocr",
        "function": "extractImageOcr"
      },
      {
        "source": "/classify-subject",
        "function": "classifySubject"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "functions": {
      "port": 5001
    },
    "hosting": {
      "port": 5000
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
